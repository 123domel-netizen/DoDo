{
  "name": "kalendarz-todo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kalendarz + ToDo PWA w stylu Notion Calendar",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "release:sync": "node scripts/sync-app-release.mjs",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name dodo && npm run release:sync",
    "worker:deploy": "npm run deploy --prefix worker",
    "worker:dev": "npm run dev --prefix worker",
    "icons:generate": "node scripts/generate-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "date-fns": "^3.6.0",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rrule": "^2.8.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^4.1.10"
  }
}
