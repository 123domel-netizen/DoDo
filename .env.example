# Skopiuj do .env i uzupełnij, aby włączyć synchronizację w chmurze (Supabase).
# Bez tych zmiennych aplikacja działa w trybie lokalnym (IndexedDB) na jednym urządzeniu.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Klucz publiczny VAPID do powiadomień Web Push (generowany razem z Edge Function).
VITE_VAPID_PUBLIC_KEY=

# Identyfikator klienta OAuth Google (publiczny, z Google Cloud Console).
VITE_GOOGLE_CLIENT_ID=
